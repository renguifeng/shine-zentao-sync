{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "_说明": "可选的旧式 env 配置：Claude Code 会把 env 注入为 $ZENTAO_* / $WEBHOOK_* 环境变量，skill 在未配 zentao.conf 时回退读取。推荐改用 `zentao setup` 写全局 ~/.claude/zentao.conf（账号密码集中管理）。",
  "env": {
    "ZENTAO_ACCOUNT": "your-zentao-account",
    "ZENTAO_PASSWORD": "your-zentao-password",
    "ZENTAO_TASK_ID": "77563",
    "WEBHOOK_HOST": "localhost",
    "PORT": "9998",
    "WEBHOOK_PROJECT_NAME": "Claude2Zen",
    "WEBHOOK_SECRET": "replace-with-the-same-secret-as-server"
  }
}
